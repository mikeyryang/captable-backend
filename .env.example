# ── Django ────────────────────────────────────────────────────
SECRET_KEY=change-me-to-a-long-random-string-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgres://captable:devsecret@localhost:5432/captable

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── AWS S3 (document storage) ─────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=captable-documents
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=                    # optional CloudFront domain

# ── DocuSign ──────────────────────────────────────────────────
DOCUSIGN_INTEGRATION_KEY=                # OAuth client ID from DocuSign admin
DOCUSIGN_ACCOUNT_ID=                     # your DocuSign account GUID
DOCUSIGN_USER_ID=                        # your DocuSign user GUID
DOCUSIGN_PRIVATE_KEY_PATH=./docusign_private.pem
DOCUSIGN_BASE_URL=https://demo.docusign.net/restapi  # use account.docusign.net for prod
DOCUSIGN_WEBHOOK_SECRET=                 # HMAC secret for webhook verification

# ── Email (Anymail / SendGrid) ────────────────────────────────
SENDGRID_API_KEY=
DEFAULT_FROM_EMAIL=equity@yourcompany.com

# ── JWT ───────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_LIFETIME_MINUTES=60
JWT_REFRESH_TOKEN_LIFETIME_DAYS=7

# ── Company defaults ──────────────────────────────────────────
PLATFORM_NAME=CapTable
SUPPORT_EMAIL=support@yourplatform.com
